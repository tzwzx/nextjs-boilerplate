{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bunx agent-session-gate session-start"
      }
    ],
    "postToolUse": [
      {
        "matcher": "Edit|Write",
        "command": ".rulesync/hooks/format.sh"
      }
    ],
    "stop": [
      {
        "command": "bunx agent-session-gate stop -- bun codesweep:fix --quiet"
      }
    ]
  }
}
