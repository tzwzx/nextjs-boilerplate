{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["oxfmt.config.ts"],
  "ignorePatterns": ["**/*.d.ts"],
  "ignoreDependencies": ["agent-session-gate"],
  "duplicates": {
    "minOccurrences": 3,
  },
  "rules": {
    "unused-dev-dependencies": "error",
  },
}
