{
  "name": "nextjs-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxfmt --check . && oxlint .",
    "format": "oxfmt --write . && oxlint --fix .",
    "stylelint": "stylelint 'src/**/*.scss'",
    "stylelint:fix": "stylelint 'src/**/*.scss' --fix",
    "tsc": "tsgo --noEmit",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "knip": "knip",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "codesweep:check": "codesweep check",
    "codesweep:fix": "codesweep fix",
    "react-doctor": "bunx -y react-doctor@latest .",
    "rulesync": "bunx rulesync generate",
    "postinstall": "lefthook install && bun rulesync"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@playwright/test": "1.60.0",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260514.1",
    "babel-plugin-react-compiler": "1.0.0",
    "codesweep": "github:tzwzx/codesweep",
    "knip": "6.13.1",
    "lefthook": "2.1.6",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "sass": "1.99.0",
    "stylelint": "17.11.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "syncpack": "15.1.2",
    "typescript": "6.0.3",
    "ultracite": "7.7.0"
  },
  "engines": {
    "bun": "1.x",
    "node": "24.x"
  }
}
