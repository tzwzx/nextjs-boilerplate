{
  "name": "nextjs-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxfmt --check && oxlint",
    "fix": "oxfmt && oxlint --fix",
    "stylelint": "stylelint 'src/**/*.scss'",
    "stylelint:fix": "stylelint 'src/**/*.scss' --fix",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell",
    "spellcheck:unused": "cspell-check-unused-words",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "fallow": "fallow",
    "fallow:fix": "fallow fix --yes",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "codesweep:check": "codesweep check",
    "codesweep:fix": "codesweep fix",
    "react-doctor": "bunx -y react-doctor@latest .",
    "rulesync": "bunx rulesync generate",
    "postinstall": "lefthook install && bun rulesync"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.10.6",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@tzwzx/codesweep": "1.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "cspell": "10.0.1",
    "cspell-check-unused-words": "1.6.3",
    "fallow": "3.3.0",
    "lefthook": "2.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "syncpack": "15.3.2",
    "typescript": "6.0.3",
    "ultracite": "7.9.3"
  },
  "engines": {
    "bun": "1.x",
    "node": "24.x"
  }
}
