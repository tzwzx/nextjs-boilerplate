{
  "name": "nextjs-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxfmt --check . && oxlint .",
    "format": "oxfmt --write . && oxlint --fix .",
    "stylelint": "stylelint 'src/**/*.scss'",
    "stylelint:fix": "stylelint 'src/**/*.scss' --fix",
    "tsc": "tsgo --noEmit",
    "package-lint-semver-ranges": "syncpack lint",
    "knip": "knip",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-all": "bun scripts/check-all.ts",
    "check-all:fix": "bun scripts/check-all.ts fix",
    "react-doctor": "bunx -y react-doctor@latest .",
    "rulesync": "bunx rulesync generate",
    "postinstall": "lefthook install && bun rulesync"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.8.3",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.10",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "knip": "5.86.0",
    "lefthook": "2.1.3",
    "oxfmt": "0.38.0",
    "oxlint": "1.53.0",
    "sass": "1.98.0",
    "stylelint": "17.4.0",
    "stylelint-config-recess-order": "7.6.1",
    "stylelint-config-recommended-scss": "17.0.0",
    "syncpack": "14.2.0",
    "typescript": "5.9.3",
    "ultracite": "7.2.5",
    "yaml": "2.8.2"
  },
  "engines": {
    "bun": "1.x",
    "node": "24.x"
  }
}
